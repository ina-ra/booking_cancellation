POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=booking_cancellation
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=set-in-local-env
POSTGRES_SSLMODE=disable

DEFAULT_HIGH_RISK_THRESHOLD=0.7
DEFAULT_BATCH_RISK_SHARE=0.3
RANDOM_STATE=42
TEST_SIZE=0.2

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=booking-cancellation-artifacts
S3_ACCESS_KEY=set-in-local-env
S3_SECRET_KEY=set-in-local-env
S3_REGION=us-east-1
S3_ARTIFACTS_PREFIX=artifacts
S3_AUTO_CREATE_BUCKET=true
S3_USE_PATH_STYLE=true

MINIO_ROOT_USER=set-in-local-env
MINIO_ROOT_PASSWORD=set-in-local-env
